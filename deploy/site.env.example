# deploy/site.env.example — copy to deploy/site.env and fill in your values.
# site.env is git-ignored; never commit real credentials.

NFS_ROOT=/shared
CONDA_PREFIX_SHARED=/shared/miniforge3

SACCT_ENABLED=auto
SLURM_ACCOUNT=default
SLURM_QOS=normal
SLURM_PARTITION=gpu

GPUUSERS_GROUP=gpuusers
ADMIN_GROUP=gpuadmins
GATEWAY_SHARED_USER=0
GATEWAY_SHARED_USER_NAME=shared

GATEWAY_HOST=10.35.4.100
GATEWAY_PORT=2225

CLUSTER_NAME=IIT GPU Cluster
CLUSTER_LOCATION=IIT-CityCampus-SpencerBuilding
CLUSTER_TZ_OFFSET=+05:30

# Required for email: https://resend.com/api-keys
RESEND_API_KEY=
MAIL_FROM=Your Cluster <no-reply@yourdomain.example>
NOTIFY_MAIL_TYPES=BEGIN,END,FAIL,REQUEUE,TIME_LIMIT

UID_MIN=2000
UID_MAX=60000
MAX_GPUS=8
MAX_CPUS=64
MAX_MEM_GB=256
MAX_HOURS=72
