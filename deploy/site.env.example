# deploy/site.env.example — copy to deploy/site.env and edit for your cluster.
# deploy/site.env is git-ignored (never commit site-specific values or secrets).
# Precedence: real environment variables > deploy/site.env > built-in defaults.

# ── Storage ────────────────────────────────────────────────────────────────────
NFS_ROOT=/shared
JOBS_SUBDIR=jobs
CONDA_PREFIX_SHARED=/shared/miniforge3

# ── SLURM accounting ───────────────────────────────────────────────────────────
# auto = enable sacct history if the sacct binary is on PATH
SACCT_ENABLED=auto
SLURM_ACCOUNT=default
SLURM_QOS=normal
SLURM_PARTITION=gpu

# ── Identity model ─────────────────────────────────────────────────────────────
# POSIX group that gates the forced-TUI (sshd Match Group) and owns job dirs.
GPUUSERS_GROUP=gpuusers
# POSIX group whose members get the admin panel.
ADMIN_GROUP=gpuadmins
# Legacy shared-account mode. 1 = run SLURM CLI as GATEWAY_SHARED_USER_NAME via
# sudo (one shared identity). 0 = per-user identity (recommended; jobs run as the
# logged-in user and attribute correctly in sacct/fairshare).
GATEWAY_SHARED_USER=0
GATEWAY_SHARED_USER_NAME=daham

# ── Gateway / SSH tunnels (printed in notebook & service hints) ─────────────────
# The public-facing host/port users SSH to from their laptops.
GATEWAY_HOST=your-gateway.example.edu
GATEWAY_PORT=22

# ── Onboarding (iit-gpu-adduser/deluser) ───────────────────────────────────────
# SSH target for the GPU/compute host (must allow passwordless sudo or key auth).
GPU_HOST_SSH=root-daham@192.168.122.1
# UID allocation range for provisioned users (kept free on both nodes).
UID_MIN=2000
UID_MAX=60000
