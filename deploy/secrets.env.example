# deploy/secrets.env.example — copy to deploy/secrets.env, fill in, and lock down:
#   sudo cp secrets.env.example secrets.env
#   sudo chown root:gpusync secrets.env
#   sudo chmod 640 secrets.env
#
# secrets.env is readable ONLY by root (the SLURM mailer) and the gpusync group
# (the audit daemon). Regular users must NEVER be able to read it. The audit
# daemon is the only in-process mail sender for the TUI, so user/admin processes
# never need the key.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Optional: override the From address (also settable in site.env)
MAIL_FROM=GPU Cluster <no-reply@example.com>
