Defaults:%gpuadmins !lecture, !use_pty, timestamp_timeout=0

%gpuadmins ALL=(root) NOPASSWD: \
    /usr/bin/scontrol update *, \
    /usr/bin/scontrol reconfigure, \
    /usr/local/bin/iit-gpu-adduser, \
    /usr/local/bin/iit-gpu-deluser, \
    /usr/sbin/chpasswd, \
    /usr/bin/sacctmgr, \
    /usr/bin/scancel
