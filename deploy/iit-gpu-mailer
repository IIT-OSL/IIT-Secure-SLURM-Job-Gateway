    bb      = pal["badge_bg"]
    bf      = pal["badge_fg"]
    icon    = pal["icon"]
    headline = _HEADLINES.get(event, "Job update")
    subtitle = _SUBTITLES.get(event, "")
    tip      = _TIPS.get(event, "")

