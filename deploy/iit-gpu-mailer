    "REQUEUED": "#8B5CF6",
    "OOM":      "#EF4444",
    "UNKNOWN":  "#6B7280",
}

_HEADLINES = {
    "STARTED":  "Job is now running",
    "ENDED":    "Job completed",
    "FAILED":   "Job failed",
    "TIMEOUT":  "Job exceeded time limit",
    "REQUEUED": "Job has been requeued",
    "OOM":      "Job ran out of memory",
    "UNKNOWN":  "Job status update",
}

_SUBTITLES = {
    "STARTED":  "Your GPU job has been allocated resources and is executing.",
