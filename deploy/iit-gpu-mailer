    job_name  = details.get("JobName") or info.get("job_name", "")
    user      = details.get("User", "")
    partition = details.get("Partition", "")
    nodes     = details.get("NodeList", "")
    cpus      = details.get("AllocCPUS", "")
    gpus      = extract_gpu_count(details.get("ReqTRES", ""))
    state     = details.get("State") or info.get("state", event)
    exit_code = details.get("ExitCode") or info.get("exit_code", "")
    elapsed   = details.get("Elapsed") or info.get("runtime", "")
    timelimit = details.get("Timelimit", "")
    submit    = details.get("Submit", "")
    start     = details.get("Start", "")
    end       = details.get("End", "")
    workdir   = details.get("WorkDir", "")
    stdout    = details.get("StdOut", "")
    stderr    = details.get("StdErr", "")

    badge_label = state if state else event

    rows = (
        _row("Job ID",      job_id,    accent) +
        _row("Job name",    job_name,  accent) +
        _row("User",        user,      accent) +
        _row("Partition",   partition, accent) +
        _row("Node(s)",     nodes,     accent) +
        _row("CPUs",        cpus,      accent) +
        _row("GPUs",        gpus,      accent) +
