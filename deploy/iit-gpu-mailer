# ── Subject line for Resend ───────────────────────────────────────────────────
def build_subject(info: dict, details: dict) -> str:
    event    = info.get("event", "UNKNOWN")
    job_name = details.get("JobName") or info.get("job_name") or "job"
    job_id   = info.get("job_id") or details.get("JobID", "")
    labels   = {
        "STARTED":  f'Job "{job_name}" is running',
        "ENDED":    f'Job "{job_name}" completed ✓',
        "FAILED":   f'Job "{job_name}" failed ✗',
        "TIMEOUT":  f'Job "{job_name}" timed out ⏱',
        "REQUEUED": f'Job "{job_name}" requeued ↺',
        "OOM":      f'Job "{job_name}" ran out of memory ⚡',
        "UNKNOWN":  f'Job update — {info.get("raw_subject", "")}',
    }
    suffix = f" [#{job_id}]" if job_id else ""
    return labels.get(event, f'Job update "{job_name}"') + suffix

# ── Send via Resend API (curl) ────────────────────────────────────────────────
def send_resend(to: str, subject: str, html: str) -> None:
    payload = json.dumps({
        "from": FROM_ADDR,
        "to":   [to],
        "subject": subject,
        "html": html,
    })
    result = subprocess.run(
        [
            "curl", "-s", "-w", "\n%{http_code}",
            "-X", "POST", "https://api.resend.com/emails",
            "-H", f"Authorization: Bearer {RESEND_API_KEY}",
            "-H", "Content-Type: application/json",
            "-d", payload,
        ],
        capture_output=True, text=True, timeout=20,
    )
    lines = result.stdout.strip().rsplit("\n", 1)
    body = lines[0] if len(lines) > 0 else ""
    code = lines[-1] if len(lines) > 1 else "0"
    if not code.startswith("2"):
        sys.stderr.write(f"iit-gpu-mailer: Resend error HTTP {code}: {body}\n")
        sys.exit(1)
    sys.stderr.write(f"iit-gpu-mailer: sent to {to} — HTTP {code} {body}\n")

# ── Fallback: pipe to msmtp for plain-text ────────────────────────────────────
def fallback_msmtp(to: str, subject: str, body_stdin: str) -> None:
    try:
        subprocess.run(["/usr/bin/msmtp", "-s", subject, to],
                       input=body_stdin, text=True, timeout=30)
    except Exception as exc:
        sys.stderr.write(f"iit-gpu-mailer: msmtp fallback failed: {exc}\n")

# ── Main ──────────────────────────────────────────────────────────────────────
def main() -> None:
    subject, recipient = parse_args(sys.argv)
    stdin_body = sys.stdin.read()

    if not recipient:
        sys.stderr.write("iit-gpu-mailer: no recipient — aborting\n")
        sys.exit(1)

    info    = parse_slurm_subject(subject)
    details = sacct_details(info["job_id"]) if info["job_id"] else {}

    html       = build_html(info, details, recipient)
    nice_subj  = build_subject(info, details)

    try:
        send_resend(recipient, nice_subj, html)
    except Exception as exc:
        sys.stderr.write(f"iit-gpu-mailer: Resend failed ({exc}), falling back to msmtp\n")
        fallback_msmtp(recipient, subject, stdin_body)

if __name__ == "__main__":
    main()
