#!/usr/bin/env python3
"""iit-gpu-mailer — SLURM MailProg wrapper that sends rich HTML emails via Resend API.

SLURM calls this as:  iit-gpu-mailer -s "SLURM Job_id=N Name=X ..." recipient@email

The script parses the subject, queries sacct for live job details, builds a
branded HTML email, and POSTs it to api.resend.com.
"""
from __future__ import annotations

