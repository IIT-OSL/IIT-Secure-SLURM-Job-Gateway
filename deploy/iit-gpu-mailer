def _row(label: str, value: str, accent: str) -> str:
    if not value or value.strip() in ("", "Unknown", "None", "N/A"):
        return ""
    return f"""
      <tr>
        <td style="padding:10px 16px;color:#6B7280;font-size:13px;white-space:nowrap;border-bottom:1px solid #F3F4F6;width:140px">{label}</td>
        <td style="padding:10px 16px;color:#111827;font-size:13px;font-family:monospace;border-bottom:1px solid #F3F4F6;word-break:break-all">{value}</td>
      </tr>"""

