def _row(label: str, value: str) -> str:
    if not value or value.strip() in ("", "Unknown", "None", "N/A", "?"):
        return ""
    return f"""<tr>
        <td style="padding:9px 0;color:#6B7280;font-size:12px;font-weight:500;text-transform:uppercase;letter-spacing:0.6px;white-space:nowrap;width:130px;vertical-align:top">{label}</td>
        <td style="padding:9px 0 9px 16px;color:#E5E7EB;font-size:13px;font-family:'SF Mono',SFMono-Regular,'Cascadia Code',Consolas,monospace;word-break:break-all;vertical-align:top">{value}</td>
      </tr>"""

def build_html(info: dict, details: dict, recipient: str) -> str:
