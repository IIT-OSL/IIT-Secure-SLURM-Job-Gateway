#!/usr/bin/env python3
"""iit-gpu-mailer — SLURM MailProg wrapper that sends rich HTML emails via Resend API.

SLURM calls this as:  iit-gpu-mailer -s "SLURM Job_id=N Name=X ..." recipient@email

The script parses the subject, queries sacct for live job details, builds a
branded HTML email, and POSTs it to api.resend.com.
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import sys
from datetime import datetime

# ── Config ────────────────────────────────────────────────────────────────────
RESEND_API_KEY = "***REDACTED_RESEND_API_KEY***"
FROM_ADDR      = "IIT GPU Gateway <admin@gpu.indrajith.net>"
CLUSTER_NAME   = "IIT GPU Cluster"
CLUSTER_URL    = "https://gpu.indrajith.net"   # update if you have a web portal

# ── Argument parsing ──────────────────────────────────────────────────────────
def parse_args(argv: list[str]) -> tuple[str, str]:
    """Return (subject, recipient). SLURM calls us as: mailer -s SUBJECT RECIPIENT"""
    subject = ""
    recipient = ""
    i = 1
    while i < len(argv):
        if argv[i] == "-s" and i + 1 < len(argv):
            subject = argv[i + 1]
            i += 2
        else:
            recipient = argv[i]
            i += 1
    return subject, recipient

# ── SLURM subject parsing ─────────────────────────────────────────────────────
def parse_slurm_subject(subject: str) -> dict:
    """Extract job_id, job_name, event from a SLURM subject line."""
    info: dict = {"raw_subject": subject, "job_id": "", "job_name": "", "event": "UNKNOWN",
                  "runtime": "", "state": "", "exit_code": ""}

    m = re.search(r"Job_id=(\d+)", subject)
    if m:
        info["job_id"] = m.group(1)

    m = re.search(r"Name=(\S+)", subject)
    if m:
        info["job_name"] = m.group(1)

    s = subject.lower()
    if "began" in s or "started" in s:
        info["event"] = "STARTED"
    elif "ended" in s or "completed" in s:
        info["event"] = "ENDED"
        m = re.search(r"Run time\s+([\d:]+)", subject, re.I)
        if m:
            info["runtime"] = m.group(1)
        m = re.search(r"ExitCode\s+(\d+)", subject, re.I)
        if m:
            info["exit_code"] = m.group(1)
        info["state"] = "COMPLETED"
    elif "failed" in s:
        info["event"] = "FAILED"
        m = re.search(r"Run time\s+([\d:]+)", subject, re.I)
        if m:
            info["runtime"] = m.group(1)
        m = re.search(r"ExitCode\s+(\d+)", subject, re.I)
        if m:
            info["exit_code"] = m.group(1)
        info["state"] = "FAILED"
    elif "time limit" in s or "timeout" in s:
        info["event"] = "TIMEOUT"
        info["state"] = "TIMEOUT"
    elif "requeue" in s:
        info["event"] = "REQUEUED"
        info["state"] = "REQUEUED"
    elif "out_of_memory" in s or "out of memory" in s:
        info["event"] = "OOM"
        info["state"] = "OUT_OF_MEMORY"

    return info

# ── sacct query ───────────────────────────────────────────────────────────────
def sacct_details(job_id: str) -> dict:
    """Query sacct for the job. Returns a dict of fields (empty strings on failure)."""
    fields = "JobID,JobName,User,Partition,NodeList,AllocCPUS,ReqTRES,State,ExitCode,Elapsed,Timelimit,Submit,Start,End,WorkDir,StdOut,StdErr"
    try:
        result = subprocess.run(
            ["sacct", "-j", job_id, "--format", fields, "--noheader",
             "--parsable2", "--units=G"],
            capture_output=True, text=True, timeout=10
        )
        lines = [l for l in result.stdout.splitlines() if l and not l.startswith("batch")]
        if not lines:
            return {}
        parts = lines[0].split("|")
        keys = [f.split("%")[0] for f in fields.split(",")]
        return dict(zip(keys, parts + [""] * len(keys)))
    except Exception:
        return {}

def extract_gpu_count(req_tres: str) -> str:
    """Extract GPU count from TRES string like cpu=4,mem=16G,node=1,gres/gpu=1"""
    m = re.search(r"gres/gpu=(\d+)", req_tres or "")
    return m.group(1) if m else "?"

