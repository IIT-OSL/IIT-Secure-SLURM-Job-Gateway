def _row(label: str, value: str, accent: str) -> str:
    if not value or value.strip() in ("", "Unknown", "None", "N/A", "?"):
        return ""
    return f"""<tr>
        <td style="padding:10px 0;color:#6B7280;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.8px;white-space:nowrap;width:120px;vertical-align:top;border-bottom:1px solid #F3F4F6">{label}</td>
        <td style="padding:10px 0 10px 20px;color:#111827;font-size:13px;font-family:'SF Mono',SFMono-Regular,Consolas,monospace;word-break:break-all;vertical-align:top;border-bottom:1px solid #F3F4F6">{value}</td>
      </tr>"""

def build_html(info: dict, details: dict, recipient: str) -> str:
    event    = info.get("event", "UNKNOWN")
    accent   = _ACCENTS.get(event, _ACCENTS["UNKNOWN"])
    headline = _HEADLINES.get(event, "Job update")
    subtitle = _SUBTITLES.get(event, "")
    tip      = _TIPS.get(event, "")

    job_id    = info.get("job_id") or details.get("JobID", "")
    job_name  = details.get("JobName") or info.get("job_name", "")
    user      = details.get("User", "")
    partition = details.get("Partition", "")
    nodes     = details.get("NodeList", "")
    cpus      = details.get("AllocCPUS", "")
    gpus      = extract_gpu_count(details.get("ReqTRES", ""))
    state     = details.get("State") or info.get("state", event)
    exit_code = details.get("ExitCode") or info.get("exit_code", "")
    elapsed   = details.get("Elapsed") or info.get("runtime", "")
    timelimit = details.get("Timelimit", "")
    submit    = details.get("Submit", "")
    start     = details.get("Start", "")
    end       = details.get("End", "")
    workdir   = details.get("WorkDir", "")
    stdout    = details.get("StdOut", "")
    stderr    = details.get("StdErr", "")

    status_label = state if state else event

    rows = (
        _row("Job ID",     job_id,    accent) +
        _row("Job Name",   job_name,  accent) +
        _row("User",       user,      accent) +
        _row("Partition",  partition, accent) +
        _row("Node(s)",    nodes,     accent) +
        _row("CPUs",       cpus,      accent) +
        _row("GPUs",       gpus,      accent) +
        _row("Submitted",  submit,    accent) +
        _row("Started",    start,     accent) +
        _row("Ended",      end,       accent) +
        _row("Elapsed",    elapsed,   accent) +
        _row("Time Limit", timelimit, accent) +
        _row("Exit Code",  exit_code, accent) +
        _row("Work Dir",   workdir,   accent) +
        _row("stdout",     stdout,    accent) +
        _row("stderr",     stderr,    accent)
    )

    tip_block = f"""<tr><td colspan="2" style="padding-top:20px;border-bottom:none">
        <div style="border-left:3px solid {accent};padding:11px 14px;background:#F9FAFB">
          <p style="margin:0;color:#374151;font-size:12px;line-height:1.7">{tip}</p>
        </div>
      </td></tr>""" if tip else ""

    now = datetime.now(__import__("datetime").timezone.utc).strftime("%d %b %Y  %H:%M UTC")

    return f"""<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head>
<body style="margin:0;padding:0;background:#F4F4F5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#F4F4F5;padding:40px 0">
    <tr><td align="center">
      <table width="580" cellpadding="0" cellspacing="0" style="max-width:580px;width:100%">

        <!-- Accent top bar — always visible, explicit td bg -->
        <tr><td bgcolor="{accent}" style="background:{accent};height:4px;font-size:0;line-height:0">&nbsp;</td></tr>

        <!-- Dark header — td bgcolor preserved by all clients -->
        <tr><td bgcolor="#111827" style="background:#111827;padding:28px 32px 26px">
          <p style="margin:0 0 20px;color:#4B5563;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase">{CLUSTER_NAME}</p>
          <h1 style="margin:0 0 8px;color:#F9FAFB;font-size:22px;font-weight:600;letter-spacing:-0.3px;line-height:1.3">{headline}</h1>
          <p style="margin:0;color:#9CA3AF;font-size:14px;line-height:1.6">{subtitle}</p>
          <!-- Status pill inside dark header -->
          <table cellpadding="0" cellspacing="0" style="margin-top:20px">
            <tr>
              <td bgcolor="#1F2937" style="background:#1F2937;border-radius:4px;padding:5px 12px">
                <span style="color:{accent};font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase">{status_label}</span>
              </td>
            </tr>
          </table>
        </td></tr>

        <!-- White content area — always readable on any client -->
        <tr><td bgcolor="#FFFFFF" style="background:#FFFFFF;padding:28px 32px 8px">
          <p style="margin:0;color:#9CA3AF;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase">Job Details</p>
        </td></tr>

        <tr><td bgcolor="#FFFFFF" style="background:#FFFFFF;padding:4px 32px 28px">
          <table width="100%" cellpadding="0" cellspacing="0">
            {rows}
            {tip_block}
          </table>
        </td></tr>

        <!-- Footer -->
        <tr><td bgcolor="#F4F4F5" style="background:#F4F4F5;padding:18px 32px;border-top:1px solid #E4E4E7">
          <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td style="color:#A1A1AA;font-size:11px">{CLUSTER_NAME} &nbsp;·&nbsp; {now}</td>
              <td align="right" style="color:#A1A1AA;font-size:11px;font-family:monospace">iit-gpu-manager</td>
            </tr>
            <tr>
              <td colspan="2" style="padding-top:6px;color:#A1A1AA;font-size:11px">By: IIT Research Team</td>
            </tr>
          </table>
        </td></tr>

      </table>
    </td></tr>
  </table>
</body>
</html>"""

# ── Subject line for Resend ───────────────────────────────────────────────────
def build_subject(info: dict, details: dict) -> str:
    event    = info.get("event", "UNKNOWN")
    job_name = details.get("JobName") or info.get("job_name") or "job"
    job_id   = info.get("job_id") or details.get("JobID", "")
    labels   = {
        "STARTED":  f'[IIT GPU] Job "{job_name}" is running',
        "ENDED":    f'[IIT GPU] Job "{job_name}" completed',
        "FAILED":   f'[IIT GPU] Job "{job_name}" failed',
        "TIMEOUT":  f'[IIT GPU] Job "{job_name}" exceeded time limit',
        "REQUEUED": f'[IIT GPU] Job "{job_name}" requeued',
        "OOM":      f'[IIT GPU] Job "{job_name}" out of memory',
        "UNKNOWN":  f'[IIT GPU] Job update — {info.get("raw_subject", "")}',
    }
    suffix = f" [#{job_id}]" if job_id else ""
    return labels.get(event, f'Job update "{job_name}"') + suffix

# ── Send via Resend API (urllib — key never exposed in argv/ps) ───────────────
def send_resend(to: str, subject: str, html: str) -> None:
    if not RESEND_API_KEY:
        sys.stderr.write("iit-gpu-mailer: RESEND_API_KEY not set — using msmtp fallback\n")
        raise RuntimeError("no API key")
    # Job notices go ONLY to the job owner — admins are never BCC'd.
    payload_dict = {
        "from": FROM_ADDR, "to": [to], "subject": subject, "html": html,
    }
    data = json.dumps(payload_dict).encode()
    req = urllib.request.Request(
        "https://api.resend.com/emails",
        data=data,
        headers={"Authorization": f"Bearer {RESEND_API_KEY}",
                 "User-Agent": "iit-gpu-mailer/1.0",
                 "Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=20) as resp:
            sys.stderr.write(f"iit-gpu-mailer: sent to {to} — HTTP {resp.status}\n")
    except urllib.error.HTTPError as exc:
        sys.stderr.write(f"iit-gpu-mailer: Resend HTTP {exc.code}: {exc.reason}\n")
        raise

# ── Fallback: pipe to msmtp for plain-text ────────────────────────────────────
def fallback_msmtp(to: str, subject: str, body_stdin: str) -> None:
    # NOTE: msmtp has no `-s` flag (that is a mailx/sendmail option). msmtp reads
    # the entire RFC-822 message — headers included — from stdin and takes the
    # recipient as a positional arg. Build a minimal message with a Subject
    # header so the fallback actually produces a valid email instead of erroring
    # out with "invalid option -- 's'".
    message = f"Subject: {subject}\nTo: {to}\n\n{body_stdin}"
    try:
        subprocess.run(["/usr/bin/msmtp", to],
                       input=message, text=True, timeout=30)
    except Exception as exc:
        sys.stderr.write(f"iit-gpu-mailer: msmtp fallback failed: {exc}\n")

# ── Main ──────────────────────────────────────────────────────────────────────
def main() -> None:
    # Admin kill-switch: a flag file on the share disables ALL outbound mail.
    # Exit cleanly so slurmctld doesn't log a MailProg failure.
    if os.path.exists(os.path.join(os.environ.get("NFS_ROOT", "/shared"), ".mail-disabled")):
        sys.exit(0)
    subject, recipient = parse_args(sys.argv)
    stdin_body = sys.stdin.read()

    if not recipient:
        sys.stderr.write("iit-gpu-mailer: no recipient — aborting\n")
        sys.exit(1)

    info    = parse_slurm_subject(subject)
    details = sacct_details(info["job_id"]) if info["job_id"] else {}

    html       = build_html(info, details, recipient)
    nice_subj  = build_subject(info, details)

    try:
        send_resend(recipient, nice_subj, html)
    except Exception as exc:
        sys.stderr.write(f"iit-gpu-mailer: Resend failed ({exc}), falling back to msmtp\n")
        fallback_msmtp(recipient, subject, stdin_body)

if __name__ == "__main__":
    main()
