#!/bin/bash
# /usr/local/bin/iit-gpu-gateway  — ForceCommand entry point for gpuusers.
#
# Forwards file-transfer sub-commands, runs the TUI for everything else:
#   scp  -P PORT -r "/local/" user@host:"/shared/folder/"   (legacy scp protocol)
#   rsync -e "ssh -p PORT" "/local/" user@host:"/shared/"   (rsync)
#   scp  -P PORT -r "/local/" user@host:"/shared/folder/"   (modern scp — uses SFTP internally)
#
# Modern OpenSSH scp (9.0+, default on Windows/Mac) uses sftp-server rather
# than the old "scp -t" protocol. SSH_ORIGINAL_COMMAND will be
# "/usr/lib/openssh/sftp-server" in that case, not "scp -t /path".
#
# NFS_ROOT is baked in at install time by deploy/install.sh.
NFS_ROOT="__NFS_ROOT__"

_ORIG="${SSH_ORIGINAL_COMMAND:-}"

# ── Guard: reject shell-injection metacharacters before any passthrough ───────
case "$_ORIG" in
    *\;*|*\`*|*'$('*|*'&&'*|*'||'*|*'>'*|*'<'*)
        printf 'iit-gpu: shell metacharacters not permitted in transfer commands.\n' >&2
        exit 1 ;;
esac

# ── Guard: reject path traversal ─────────────────────────────────────────────
case "$_ORIG" in
    */../*|*'/..'|*' ..'*)
        printf 'iit-gpu: path traversal (..) not permitted.\n' >&2
        exit 1 ;;
esac

# ── Path jail check (scp/rsync — path is last token) ─────────────────────────
_path_ok() {
    local raw="${_ORIG##* }"
    raw="${raw%/}"
    raw="${raw#\"}" raw="${raw%\"}"
    raw="${raw#\'}" raw="${raw%\'}"
    [[ "$raw" == "." || "$raw" == "${NFS_ROOT}" || "$raw" == "${NFS_ROOT}/"* ]]
}

# ── Transfer audit (best-effort — never blocks the transfer) ──────────────────
# auditclient.log() builds a proper event (ts/session/remote) and delivers it
# over the stream socket; SO_PEERCRED stamps the authoritative user on ingest.
_audit_transfer() {
    local kind="$1" path="$2"
    python3 -c \
        "from iitgpu import auditclient; auditclient.log('transfer_${kind}', detail='${path}')" \
        2>/dev/null || true
}

# ── Route ─────────────────────────────────────────────────────────────────────
# Use "eval exec" rather than "exec /bin/bash -c" so that the transfer binary
# replaces this process directly — no new bash subprocess, no .bashrc sourcing.
case "$_ORIG" in
    scp\ *-t\ *|scp\ *-f\ *)
        _path_ok || { printf 'iit-gpu: scp path outside %s — denied.\n' "${NFS_ROOT}" >&2; exit 1; }
        _audit_transfer "scp" "${_ORIG##* }"
        eval exec "$_ORIG"
        ;;
    rsync\ --server\ *)
        _path_ok || { printf 'iit-gpu: rsync path outside %s — denied.\n' "${NFS_ROOT}" >&2; exit 1; }
        _audit_transfer "rsync" "${_ORIG##* }"
        eval exec "$_ORIG"
        ;;
    *sftp-server*)
        # Modern scp (OpenSSH 9+, default on Windows and macOS) uses the SFTP
        # subsystem internally. SSH_ORIGINAL_COMMAND is the sftp-server binary
        # path, not "scp -t /path". sftp-server runs as the authenticated user
        # so filesystem permissions are the security boundary.
        _audit_transfer "sftp" "sftp-session"
        eval exec "$_ORIG"
        ;;
esac

# Interactive SSH or unrecognised sub-command → start the TUI.
exec /usr/local/bin/iit-gpu-manager
