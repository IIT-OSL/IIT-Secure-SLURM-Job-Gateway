# deploy/images/data-science.def — Apptainer definition for data-science
# Build: sudo apptainer build /shared/images/data-science.sif deploy/images/data-science.def
# Requires: CUDA 12.8 driver on the host (RTX 5090 sm_120)

Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

%environment
    export PATH=/opt/conda/bin:$PATH
    export CONDA_PREFIX=/opt/conda

%post
    # System dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        wget curl git ca-certificates build-essential && \
        rm -rf /var/lib/apt/lists/*

    # Miniforge (conda)
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh
    /opt/conda/bin/conda init bash

    # Data science + JupyterLab (+ optional RAPIDS cuDF comment)
    /opt/conda/bin/pip install --no-cache-dir \
        torch==2.7.* --index-url https://download.pytorch.org/whl/cu128
    /opt/conda/bin/pip install --no-cache-dir \
        scikit-learn>=1.4 xgboost>=2.0 lightgbm \
        pandas>=2.0 numpy matplotlib seaborn \
        jupyterlab>=4.0 ipywidgets plotly
    # Optional RAPIDS cuDF (GPU DataFrame — uncomment if needed):
    # /opt/conda/bin/pip install --no-cache-dir cudf-cu12 --extra-index-url https://pypi.nvidia.com

%runscript
    exec python3 "$@"

%labels
    org.label-schema.name "IIT Data Science — CUDA 12.8 / PyTorch 2.7 / JupyterLab"
