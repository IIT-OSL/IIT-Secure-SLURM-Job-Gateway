# deploy/images/llm-finetune.def — Apptainer definition for llm-finetune
# Build: sudo apptainer build /shared/images/llm-finetune.sif deploy/images/llm-finetune.def
# Requires: CUDA 12.8 driver on the host (RTX 5090 sm_120)

Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

%environment
    export PATH=/opt/conda/bin:$PATH
    export CONDA_PREFIX=/opt/conda

%post
    # System dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        wget curl git ca-certificates build-essential && \
        rm -rf /var/lib/apt/lists/*

    # Miniforge (conda)
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh
    /opt/conda/bin/conda init bash

    # PyTorch 2.7 + cu128 + LLM finetuning stack
    /opt/conda/bin/pip install --no-cache-dir \
        torch==2.7.* torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu128
    /opt/conda/bin/pip install --no-cache-dir \
        transformers>=4.40 peft>=0.11 trl>=0.8 \
        bitsandbytes>=0.43 accelerate>=0.30 \
        datasets>=2.19 safetensors sentencepiece

%runscript
    exec python3 "$@"

%labels
    org.label-schema.name "IIT LLM Finetune — CUDA 12.8 / PyTorch 2.7 / sm_120"
    org.label-schema.description "LoRA/QLoRA finetuning for 7-8B models (4-bit fits RTX 5090 32 GB)"
