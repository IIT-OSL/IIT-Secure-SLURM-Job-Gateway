Bootstrap: docker
From: ubuntu:22.04

%environment
    export PATH=/opt/conda/bin:$PATH
    export PIP_NO_CACHE_DIR=1
    export DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive
    export PIP_NO_CACHE_DIR=1
    export PATH=/opt/conda/bin:$PATH

    apt-get update -qq
    apt-get install -y --no-install-recommends \
        wget curl git ca-certificates build-essential
    apt-get clean && rm -rf /var/lib/apt/lists/*

    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/mf.sh
    bash /tmp/mf.sh -b -p /opt/conda && rm /tmp/mf.sh

    pip install --no-cache-dir \
        torch==2.7.* torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu128

    pip install --no-cache-dir \
        transformers>=4.40 peft>=0.11 trl>=0.8 \
        bitsandbytes>=0.43 accelerate>=0.30 \
        datasets>=2.19 safetensors sentencepiece

    rm -rf /opt/conda/pkgs/* /tmp/* /root/.cache

%runscript
    exec python3 "$@"

%labels
    Name "IIT llm-finetune — PyTorch 2.7 cu128 sm_120"
