# deploy/images/diffusion.def — Apptainer definition for diffusion
# Build: sudo apptainer build /shared/images/diffusion.sif deploy/images/diffusion.def
# Requires: CUDA 12.8 driver on the host (RTX 5090 sm_120)

Bootstrap: docker
From: nvcr.io/nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

%environment
    export PATH=/opt/conda/bin:$PATH
    export CONDA_PREFIX=/opt/conda

%post
    # System dependencies
    apt-get update && apt-get install -y --no-install-recommends \
        wget curl git ca-certificates build-essential && \
        rm -rf /var/lib/apt/lists/*

    # Miniforge (conda)
    wget -q https://github.com/conda-forge/miniforge/releases/latest/download/Miniforge3-Linux-x86_64.sh -O /tmp/miniforge.sh
    bash /tmp/miniforge.sh -b -p /opt/conda
    rm /tmp/miniforge.sh
    /opt/conda/bin/conda init bash

    # Diffusion stack — Stable Diffusion / ComfyUI
    /opt/conda/bin/pip install --no-cache-dir \
        torch==2.7.* torchvision \
        --index-url https://download.pytorch.org/whl/cu128
    /opt/conda/bin/pip install --no-cache-dir \
        diffusers>=0.27 transformers>=4.40 \
        accelerate>=0.30 safetensors xformers Pillow

%runscript
    exec python3 "$@"

%labels
    org.label-schema.name "IIT Diffusion — CUDA 12.8 / PyTorch 2.7 / diffusers"
